{
	"$schema": "https://schemas.wp.org/wp/6.9/theme.json",
	"version": 3,
	"settings": {
		"appearanceTools": true,
		"useRootPaddingAwareAlignments": true,
		"layout": {
			"contentSize": "800px",
			"wideSize": "1280px"
		},
		"color": {
			"defaultColors": false,
			"defaultGradients": false,
			"defaultDuotone": false,
			"palette": [
				{
					"slug": "base",
					"color": "#faf9f6",
					"name": "Base"
				},
				{
					"slug": "contrast",
					"color": "#424940",
					"name": "Contrast"
				},
				{
					"slug": "heading",
					"color": "#1a1c1a",
					"name": "Heading"
				},
				{
					"slug": "primary",
					"color": "#026b54",
					"name": "Primary (Jungle Canopy)"
				},
				{
					"slug": "primary-container",
					"color": "#50a48a",
					"name": "Primary Container"
				},
				{
					"slug": "on-primary",
					"color": "#ffffff",
					"name": "On Primary"
				},
				{
					"slug": "secondary",
					"color": "#8b5000",
					"name": "Secondary (Golden Hour)"
				},
				{
					"slug": "secondary-container",
					"color": "#ffac56",
					"name": "Secondary Container"
				},
				{
					"slug": "on-secondary-container",
					"color": "#2d1700",
					"name": "On Secondary Container"
				},
				{
					"slug": "tertiary",
					"color": "#924941",
					"name": "Tertiary (Clay Earth)"
				},
				{
					"slug": "surface",
					"color": "#faf9f6",
					"name": "Surface (Sand & Shell)"
				},
				{
					"slug": "surface-container-lowest",
					"color": "#ffffff",
					"name": "Surface Container Lowest"
				},
				{
					"slug": "surface-container-low",
					"color": "#f3f2ef",
					"name": "Surface Container Low"
				},
				{
					"slug": "surface-container",
					"color": "#eeedea",
					"name": "Surface Container"
				},
				{
					"slug": "surface-container-high",
					"color": "#e9e8e5",
					"name": "Surface Container High"
				},
				{
					"slug": "surface-container-highest",
					"color": "#e3e2df",
					"name": "Surface Container Highest"
				},
				{
					"slug": "on-surface",
					"color": "#1a1c1a",
					"name": "On Surface"
				},
				{
					"slug": "on-surface-variant",
					"color": "#424940",
					"name": "On Surface Variant"
				},
				{
					"slug": "outline",
					"color": "#72796f",
					"name": "Outline"
				},
				{
					"slug": "outline-variant",
					"color": "#c2c9be",
					"name": "Outline Variant"
				}
			],
			"gradients": [
				{
					"slug": "primary-radial",
					"gradient": "radial-gradient(ellipse at center, #50a48a 0%, #026b54 100%)",
					"name": "Primary Radial"
				},
				{
					"slug": "primary-linear",
					"gradient": "linear-gradient(135deg, #026b54 0%, #50a48a 100%)",
					"name": "Primary Linear"
				}
			],
			"duotone": []
		},
		"typography": {
			"defaultFontSizes": false,
			"fontFamilies": [
				{
					"fontFamily": "'Epilogue', sans-serif",
					"name": "Epilogue",
					"slug": "epilogue",
					"fontFace": [
						{
							"fontFamily": "Epilogue",
							"fontStyle": "normal",
							"fontWeight": "100 900",
							"src": [
								"file:./assets/fonts/Epilogue-Variable.woff2"
							]
						}
					]
				},
				{
					"fontFamily": "'Manrope', sans-serif",
					"name": "Manrope",
					"slug": "manrope",
					"fontFace": [
						{
							"fontFamily": "Manrope",
							"fontStyle": "normal",
							"fontWeight": "200 800",
							"src": [
								"file:./assets/fonts/Manrope-Variable.woff2"
							]
						}
					]
				}
			],
			"fontSizes": [
				{
					"slug": "small",
					"size": ".875rem",
					"name": "Small"
				},
				{
					"slug": "regular",
					"size": "1rem",
					"name": "regular"
				},
				{
					"slug": "large",
					"size": "1.5rem",
					"name": "Large"
				},
				{
					"slug": "xl",
					"size": "2.25rem",
					"fluid": {
						"min": "1.5rem",
						"max": "2.25rem"
					},
					"name": "Extra Large"
				},
				{
					"slug": "2xl",
					"size": "3rem",
					"fluid": {
						"min": "2rem",
						"max": "3rem"
					},
					"name": "2X Large"
				},
				{
					"slug": "3xl",
					"size": "3.75rem",
					"fluid": {
						"min": "2.75rem",
						"max": "3.75rem"
					},
					"name": "3X Large"
				}
			]
		},
		"spacing": {
			"units": [ "%", "px", "em", "rem", "vh", "vw" ],
			"defaultSpacingSizes": false,
			"spacingSizes": [
				{
					"slug": "xs",
					"size": "1rem",
					"name": "Extra Small"
				},
				{
					"slug": "small",
					"size": "2rem",
					"name": "Small"
				},
				{
					"slug": "regular",
					"size": "4rem",
					"name": "Regular"
				},
				{
					"slug": "large",
					"size": "6rem",
					"name": "Large"
				}
			]
		},
		"border": {
			"color": true,
			"radius": true,
			"style": true,
			"width": true
		},
		"shadow": {
			"defaultPresets": false,
			"presets": [
				{
					"slug": "ambient",
					"shadow": "0 8px 40px rgba(26, 28, 26, 0.06)",
					"name": "Ambient"
				},
				{
					"slug": "float",
					"shadow": "0 12px 50px rgba(26, 28, 26, 0.08)",
					"name": "Float"
				},
				{
					"slug": "cta",
					"shadow": "0 16px 48px rgba(26, 28, 26, 0.07)",
					"name": "CTA"
				}
			]
		},
		"custom": {
			"borderRadius": {
				"sm": "0.25rem",
				"md": "0.75rem",
				"lg": "1rem",
				"full": "9999px"
			},
			"backdropBlur": "12px",
			"glassOpacity": "0.7"
		}
	},
	"styles": {
		"color": {
			"background": "var:preset|color|base",
			"text": "var:preset|color|contrast"
		},
		"typography": {
			"fontFamily": "var:preset|font-family|manrope",
			"fontSize": "var:preset|font-size|regular",
			"lineHeight": "1.7"
		},
		"spacing": {
			"blockGap": "var:preset|spacing|small",
			"padding": {
				"right": "1rem",
				"left": "1rem"
			}
		},
		"elements": {
			"heading": {
				"color": {
					"text": "var:preset|color|heading"
				}
			},
			"h1": {
				"typography": {
					"fontFamily": "var:preset|font-family|epilogue",
					"fontSize": "var:preset|font-size|3-xl",
					"fontWeight": "700",
					"lineHeight": "1.1",
					"letterSpacing": "-0.02em"
				}
			},
			"h2": {
				"typography": {
					"fontFamily": "var:preset|font-family|epilogue",
					"fontSize": "var:preset|font-size|2-xl",
					"fontWeight": "700",
					"lineHeight": "1.2",
					"letterSpacing": "-0.015em"
				}
			},
			"h3": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--epilogue)",
					"fontSize": "var:preset|font-size|xl",
					"fontWeight": "600",
					"lineHeight": "1.3",
					"letterSpacing": "-0.01em"
				}
			},
			"h4": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--epilogue)",
					"fontSize": "var(--wp--preset--font-size--headline-sm)",
					"fontWeight": "600",
					"lineHeight": "1.4"
				}
			},
			"h5": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--epilogue)",
					"fontSize": "var(--wp--preset--font-size--title-lg)",
					"fontWeight": "600",
					"lineHeight": "1.4"
				}
			},
			"h6": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--epilogue)",
					"fontSize": "var(--wp--preset--font-size--title-md)",
					"fontWeight": "600",
					"lineHeight": "1.5"
				}
			},
			"button": {
				"color": {
					"background": "var(--wp--preset--color--primary)",
					"text": "var(--wp--preset--color--on-primary)"
				},
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--manrope)",
					"fontSize": "var(--wp--preset--font-size--label-lg)",
					"fontWeight": "600",
					"letterSpacing": "0.01em"
				},
				"border": {
					"radius": "0.75rem"
				},
				"spacing": {
					"padding": {
						"top": "var(--wp--preset--spacing--3)",
						"bottom": "var(--wp--preset--spacing--3)",
						"left": "var(--wp--preset--spacing--6)",
						"right": "var(--wp--preset--spacing--6)"
					}
				}
			},
			"link": {
				"color": {
					"text": "var(--wp--preset--color--primary)"
				},
				":hover": {
					"color": {
						"text": "var(--wp--preset--color--primary-container)"
					}
				}
			}
		},
		"blocks": {
			"core/paragraph": {
				"typography": {
					"fontFamily": "var:preset|font-family|manrope"
				}
			},
			"core/image": {
				"variations": {
					"rounded": {
						"border": {
							"radius": "1.5rem"
						}
					}
				}
			},
			"core/navigation": {
				"typography": {
					"fontSize": "var:preset|font-size|small"
				},
				"spacing": {
					"blockGap": "var:preset|spacing|2"
				}
			},
			"core/site-title": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--epilogue)",
					"fontWeight": "700",
					"letterSpacing": "-0.01em"
				}
			},
			"core/buttons": {
				"spacing": {
					"blockGap": "var(--wp--preset--spacing--4)"
				}
			},
			"core/template-part": {
				"spacing": {
					"margin": {
						"top": "0rem"
					}
				}
			}
		}
	},
	"templateParts": [
		{
			"area": "header",
			"name": "header"
		},
		{
			"area": "footer",
			"name": "footer"
		}
	]
}
