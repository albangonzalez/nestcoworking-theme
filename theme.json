{
	"$schema": "https://schemas.wp.org/wp/6.9/theme.json",
	"version": 3,
	"settings": {
		"appearanceTools": true,
		"useRootPaddingAwareAlignments": true,
		"layout": {
			"contentSize": "800px",
			"wideSize": "1280px"
		},
		"color": {
			"palette": [
				{
					"slug": "base",
					"color": "#faf9f6",
					"name": "Base"
				},
				{
					"slug": "contrast",
					"color": "#424940",
					"name": "Contrast"
				},
				{
					"slug": "heading",
					"color": "#1a1c1a",
					"name": "Heading"
				},
				{
					"slug": "primary",
					"color": "#026b54",
					"name": "Primary (Jungle Canopy)"
				},
				{
					"slug": "primary-light",
					"color": "#50a48a",
					"name": "Primary Light"
				},
				{
					"slug": "secondary",
					"color": "#ffac56",
					"name": "Secondary (Golden Hour)"
				},
				{
					"slug": "surface",
					"color": "#f3f2ef",
					"name": "Surface"
				},
				{
					"slug": "indigo",
					"color": "#372aac",
					"name": "Blue (Indigo)"
				},
				{
					"slug": "violet",
					"color": "#4d179a",
					"name": "Violet"
				}
			],
			"gradients": [
				{
					"slug": "gradient-1",
					"gradient": "linear-gradient(135deg, var(--wp--preset--color--primary) 0%, var(--wp--preset--color--primary-light) 100%)",
					"name": "Primary Linear"
				},
				{
					"slug": "gradient-2",
					"gradient": "radial-gradient(ellipse at center, var(--wp--preset--color--primary-light) 0%, var(--wp--preset--color--primary) 100%)",
					"name": "Primary Radial"
				}
			]
		},
		"typography": {
			"fontFamilies": [
				{
					"fontFamily": "'Epilogue', sans-serif",
					"name": "Epilogue",
					"slug": "epilogue",
					"fontFace": [
						{
							"fontFamily": "Epilogue",
							"fontStyle": "normal",
							"fontWeight": "100 900",
							"src": [
								"file:./assets/fonts/Epilogue-Variable.woff2"
							]
						}
					]
				},
				{
					"fontFamily": "'Manrope', sans-serif",
					"name": "Manrope",
					"slug": "manrope",
					"fontFace": [
						{
							"fontFamily": "Manrope",
							"fontStyle": "normal",
							"fontWeight": "200 800",
							"src": [
								"file:./assets/fonts/Manrope-Variable.woff2"
							]
						}
					]
				}
			],
			"fontSizes": [
				{
					"slug": "small",
					"size": ".875rem",
					"name": "Small"
				},
				{
					"slug": "regular",
					"size": "1rem",
					"name": "regular"
				},
				{
					"slug": "large",
					"size": "1.5rem",
					"name": "Large"
				},
				{
					"slug": "xl",
					"size": "2.25rem",
					"fluid": {
						"min": "1.5rem",
						"max": "2.25rem"
					},
					"name": "Extra Large"
				},
				{
					"slug": "2xl",
					"size": "3rem",
					"fluid": {
						"min": "2rem",
						"max": "3rem"
					},
					"name": "2X Large"
				},
				{
					"slug": "3xl",
					"size": "3.75rem",
					"fluid": {
						"min": "2.75rem",
						"max": "3.75rem"
					},
					"name": "3X Large"
				}
			]
		},
		"spacing": {
			"units": [ "%", "px", "em", "rem", "vh", "vw" ],
			"defaultSpacingSizes": false,
			"spacingSizes": [
				{
					"slug": "2xs",
					"size": ".5rem",
					"name": "2X Small"
				},
				{
					"slug": "xs",
					"size": "1rem",
					"name": "Extra Small"
				},
				{
					"slug": "small",
					"size": "2rem",
					"name": "Small"
				},
				{
					"slug": "regular",
					"size": "4rem",
					"name": "Regular"
				},
				{
					"slug": "large",
					"size": "6rem",
					"name": "Large"
				}
			]
		},
		"border": {
			"color": true,
			"radius": true,
			"style": true,
			"width": true
		},
		"custom": {
			"border": {
				"radius": "1.5rem"
			}
		}
	},
	"styles": {
		"css": ".rounded { border-radius: var(--wp--custom--border--radius); } .p-small { padding: var(--wp--preset--spacing--xs); } .p-regular { padding: var(--wp--preset--spacing--small); }",
		"color": {
			"background": "var:preset|color|base",
			"text": "var:preset|color|contrast"
		},
		"typography": {
			"fontFamily": "var:preset|font-family|manrope",
			"fontSize": "var:preset|font-size|regular",
			"lineHeight": "1.7"
		},
		"spacing": {
			"blockGap": "var:preset|spacing|small",
			"padding": {
				"right": "1rem",
				"left": "1rem"
			}
		},
		"elements": {
			"heading": {
				"color": {
					"text": "var:preset|color|heading"
				},
				"typography": {
					"fontFamily": "var:preset|font-family|epilogue",
					"fontWeight": "700",
					"lineHeight": "1",
					"letterSpacing": "-0.022em"
				}
			},
			"h1": {
				"typography": {
					"fontSize": "var:preset|font-size|3-xl"
				}
			},
			"h2": {
				"typography": {
					"fontSize": "var:preset|font-size|2-xl"
				}
			},
			"h3": {
				"typography": {
					"fontSize": "var:preset|font-size|xl"
				}
			},
			"h4": {
				"typography": {
					"fontSize": "var:preset|font-size|large"
				}
			},
			"h5": {
				"typography": {
					"fontSize": "var:preset|font-size|regular"
				}
			},
			"h6": {
				"typography": {
					"fontSize": "var:preset|font-size|regular"
				}
			},
			"button": {
				"color": {
					"background": "var:preset|color|primary",
					"text": "var:preset|color|base"
				},
				"typography": {
					"fontWeight": "600"
				},
				"border": {
					"radius": "var:preset|spacing|small"
				},
				"spacing": {
					"padding": {
						"top": "var:preset|spacing|2-xs",
						"bottom": "var:preset|spacing|2-xs",
						"left": "var:preset|spacing|small",
						"right": "var:preset|spacing|small"
					}
				}
			},
			"link": {
				"color": {
					"text": "var:preset|color|primary"
				},
				":hover": {
					"color": {
						"text": "var:preset|color|primary-light"
					}
				}
			}
		},
		"blocks": {
			"core/image": {
				"variations": {
					"rounded": {
						"border": {
							"radius": "var:custom|border|radius"
						}
					}
				}
			},
			"core/navigation": {
				"typography": {
					"fontSize": "var:preset|font-size|small"
				},
				"spacing": {
					"blockGap": "var:preset|spacing|2"
				}
			},
			"core/buttons": {
				"spacing": {
					"blockGap": "var:preset|spacing|small"
				}
			},
			"core/button": {
				"variations": {
					"outline": {
						"color": {
							"background": "transparent",
							"text": "var:preset|color|base"
						},
						"border": {
							"color": "var:preset|color|base",
							"style": "solid",
							"width": "1px"
						},
						"spacing": {
							"padding": {
								"top": "var:preset|spacing|2-xs",
								"bottom": "var:preset|spacing|2-xs",
								"left": "var:preset|spacing|small",
								"right": "var:preset|spacing|small"
							}
						}
					}
				}
			},
			"core/template-part": {
				"spacing": {
					"margin": {
						"top": "0rem"
					}
				}
			}
		}
	},
	"templateParts": [
		{
			"area": "header",
			"name": "header"
		},
		{
			"area": "footer",
			"name": "footer"
		}
	]
}
